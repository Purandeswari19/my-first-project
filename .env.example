# Required by ADK/Gemini
GOOGLE_API_KEY=your_google_ai_studio_key

# PostgreSQL (pgAdmin-managed DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personal_assistant

# Optional customization
REMINDER_TIMEZONE=UTC
# Optional override if your MCP command differs
DB_MCP_COMMAND=python
DB_MCP_ARGS=-m personal_ai_assistant.mcp_db_server
